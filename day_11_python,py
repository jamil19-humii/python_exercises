#3. function(add_all_nums)
def add_all_nums(*args):
    total=0
    for item in args:
        if isinstance(item,(int,float)):
            total +=item
        else:
            return f"Invalid input:'{item}' is not  number."
        return total
print(add_all_nums(2,5,10))
print(add_all_nums(3,'Jamila',7))
