#6.A function to return slope of a linear equation
def calculate_slope(x1, y1, x2, y2):
    if x1 == x2:
        return "Slope is undefined (vertical line)."
    return (y2 - y1) / (x2 - x1)

print(calculate_slope(2, 4, 6, 10))   # Output: 1.5
print(calculate_slope(3, 5, 3, 9))    # Output: Slope is undefined (vertical line).
